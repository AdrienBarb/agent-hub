{
  "slug": "job-hunt",
  "name": "Job Hunt",
  "cron": "0 6 * * *",
  "timezone": "Europe/Zurich",

  "boards": {
    "jobup": {
      "listing_urls": [
        "https://www.jobup.ch/en/jobs/?term=software%20engineer",
        "https://www.jobup.ch/en/jobs/?term=full-stack%20developer",
        "https://www.jobup.ch/en/jobs/?term=frontend%20developer"
      ],
      "firecrawl": {
        "waitFor": 12000,
        "onlyMainContent": false
      }
    }
  },

  "filters": {
    "accept_all_switzerland": true,
    "cities": [
      "Zurich", "Geneva", "Lausanne", "Bern", "Basel",
      "Lugano", "Fribourg", "Neuchâtel", "Sion", "Vevey", "Montreux"
    ],
    "salary_floor_chf": 80000
  },

  "keywords": {
    "must_match": [
      "javascript", "typescript", "react", "next", "node",
      "fullstack", "full-stack", "frontend"
    ],
    "bonus": ["claude", "openai", "ai", "llm", "agent"]
  },

  "_planned": {
    "_comment": "Fields below are not consumed yet. Activated in later iterations.",
    "filters_iter2": {
      "languages_acceptable": ["en", "fr"]
    },
    "select_iter3": {
      "fit_threshold_percent": 60
    }
  }
}
