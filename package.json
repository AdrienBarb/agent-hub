{
  "name": "agent-hub",
  "version": "0.0.0",
  "private": true,
  "description": "Personal hub for autonomous AI agents",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",

    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:studio": "open http://127.0.0.1:54423",

    "db:migrate": "pnpm --filter @hub/core db:migrate",
    "db:deploy": "pnpm --filter @hub/core db:deploy",
    "db:push": "pnpm --filter @hub/core db:push",
    "db:reset": "pnpm --filter @hub/core db:reset",
    "db:wipe": "dotenv -e .env.local -- pnpm --filter @hub/core exec prisma db push --force-reset --accept-data-loss",
    "db:studio": "pnpm --filter @hub/core db:studio",
    "db:generate": "pnpm --filter @hub/core db:generate",

    "storage:setup": "dotenv -e .env.local -- tsx scripts/storage-setup.ts",

    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "jobhunt:trigger": "dotenv -e .env.local -- node -e \"import('inngest').then(m => new m.Inngest({id:'agent-hub',eventKey:process.env.INNGEST_EVENT_KEY}).send({name:'jobhunt/run.requested',data:{source:'cli'}}).then(r=>console.log('sent',r)))\""
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  }
}
