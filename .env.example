# Copy this file to .env.local and fill in the values.
# Loaded into Next.js and Prisma via dotenv-cli (see package.json scripts).

# =========================================
# Supabase
# Local: values come from `supabase status` after `pnpm supabase:start`
# Cloud: get from https://supabase.com/dashboard
# =========================================
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DATABASE_URL: pooled connection (cloud only — local = direct)
# DIRECT_URL: direct connection (used by Prisma migrations)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# =========================================
# Anthropic — https://console.anthropic.com
# =========================================
ANTHROPIC_API_KEY=

# =========================================
# Firecrawl — https://www.firecrawl.dev
# =========================================
FIRECRAWL_API_KEY=

# =========================================
# Hub access — shared secret for the dashboard auth gate
# Generate: openssl rand -hex 32
# =========================================
HUB_ACCESS_TOKEN=

# =========================================
# Inngest — https://app.inngest.com
# =========================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# =========================================
# Langfuse — https://cloud.langfuse.com
# =========================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
